rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && userRole() == "admin";
    }

    function isOperator() {
      return signedIn() && userRole() in ["admin", "operator"];
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /devices/{document=**} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /intersections/{document=**} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /traffic_data/{document=**} {
      allow read: if signedIn();
      allow write: if isOperator();
    }

    match /signal_status/{document=**} {
      allow read: if signedIn();
      allow write: if isOperator();
    }

    match /emergency_logs/{document=**} {
      allow read: if signedIn();
      allow create: if isOperator();
      allow update, delete: if isAdmin();
    }

    match /analytics/{document=**} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /system_logs/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
